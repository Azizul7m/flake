{
    "layer": "top",
    "height": 24,
    "spacing": 5,
    "position": "top",
    "modules-left": [
      "hyprland/workspaces",
      "wlr/taskbar",
      "hyprland/window"
    ],
    "modules-center": ["clock", "mpd"],
    "modules-right": [
        "network",
        "tray",
        "hyprland/language",
        "pulseaudio",
        "cpu",
        "battery",
        "custom/notification"
