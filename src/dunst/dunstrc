[global]
    follow= mouse
    # geometry= "0x0-30+20"
    indicate_hidden= yes
    shrink= no
    transparency= 0
    padding= 5
    frame_width = 0
    sort = yes
    line_height= 0
    markup= full
    alignment= left
    word_wrap= yes
    stack_duplicates= false
    hide_duplicate_count= false
    show_indicators= yes
    icon_position= left
    # max_icon_size= 32
    history_length= 20
    browser = /usr/bin/xdg-open
    title= Dunst
    class= Dunst

    # Offset from the origin
    origin = bottom-left
    offset = 10x60
    # hlcolor="#fff"
    # bgcolor="#101010"
    background = "#001326"
    foreground = "#f0f0f0"
    transparency= 0.5

[urgency_low]
    timeout = 5

[urgency_normal]
    timeout = 8

[urgency_critical]
    timeout = 15

